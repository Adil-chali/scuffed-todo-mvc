<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="css/style.css">
</head>
<body>
    <h1>Todos</h1>
    <ul>
    <% todos.forEach( el => { %>
        <li class='todoItem' data-id='<%=el._id%>'>
        <% if (el.picture) { %>
        <img src="<%= el.picture %>" alt="Todo image">
        <% } %>
            <span class='<%= el.completed === true ? 'completed' : 'not'%>'><%= el.todo %></span>
            <span class='del'> Delete </span>
        </li>
    <% }) %>    
    </ul>

    <h2>Things left to do: <%= left %></h2>


    <form id="todoForm">
    <input type="text" placeholder="Enter Todo Item" name="todoItem" id="todoItem" required>
    <input type="file" id="fileElem" accept="image/*">
    <button type="submit" id="submitBtn">Add Todo</button>
    </form>
    <div id="uploadStatus" style="display:none; color:green;"></div>
    <div id="loading" style="display:none;">Processing your todo...</div>
    <script src="js/main.js"></script>
</body>
</html>